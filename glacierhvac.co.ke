<div class="modal-overlay" id="mpesa-modal">
  <div class="modal-box">
    <div class="flex items-center justify-between p-6 border-b border-gray-100">
      <h3 class="text-xl font-bold text-gray-900 flex items-center gap-2"><i class="fas fa-mobile-alt text-green-600"></i> Pay via M-Pesa</h3>
      <button onclick="closeModal('mpesa-modal')" class="w-8 h-8 bg-gray-100 hover:bg-gray-200 rounded-full flex items-center justify-center text-gray-500 transition-colors"><i class="fas fa-times text-sm"></i></button>
    </div>
    <div class="p-6">

      <!-- Success -->
      <div class="pay-success" id="mpesa-success">
        <div class="ok-icon"><i class="fas fa-check"></i></div>
        <h4 class="text-xl font-bold text-gray-900 mb-2">STK Push Sent!</h4>
        <p class="text-gray-600 text-sm">Check your phone — enter your M-Pesa PIN to complete payment.</p>
      </div>

      <div id="mpesa-form-wrap">
        <!-- Till banner -->
        <div class="bg-green-600 rounded-xl p-4 mb-5 text-center">
          <p class="text-green-100 text-xs uppercase tracking-widest mb-1">Lipa Na M-Pesa · Till Number</p>
          <p class="text-white text-4xl font-extrabold tracking-wider">9281612</p>
          <p class="text-green-200 text-xs mt-1">Evan MWAITA Mwashuke · Glacier HVAC</p>
          <button onclick="copyText('9281612',this)" class="mt-2 bg-white/20 hover:bg-white/30 text-white text-xs font-bold px-4 py-1.5 rounded-lg transition-colors inline-flex items-center gap-1 mx-auto">
            <i class="fas fa-copy"></i> Copy Till
          </button>
        </div>

        <!-- STK Push form -->
        <p class="text-center text-xs text-gray-400 font-semibold mb-3">— OR get an instant push to your phone —</p>
        <div id="stk-alert" class="alert-er"></div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1">Your Name</label>
            <input type="text" id="stk-name" class="stk-input" placeholder="John Mwangi">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1">M-Pesa Phone Number *</label>
