<title>Glacier HVAC Solutions | Mombasa, Kenya</title>
<meta name="description" content="Glacier HVAC Solutions — Expert AC installation, heating repair & maintenance in Mombasa, Kenya. 24/7 emergency service. Call +254716091861."/>

<!-- ✅ Tailwind from CDN (fixes broken local path) -->
<script src="https://cdn.tailwindcss.com"></script>
<!-- ✅ Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<!-- ✅ Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<!-- ✅ Flutterwave SDK — M-Pesa STK Push + Visa/Mastercard -->
<script src="https://checkout.flutterwave.com/v3.js"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          glacier: { 50:'#eff6ff', 100:'#dbeafe', 500:'#3b82f6', 600:'#2563eb', 700:'#1d4ed8', 800:'#1e40af', 900:'#1e3a8a' }
        },
        fontFamily: { inter: ['Inter','sans-serif'] }
      }
    }
  }
</script>

<style>
  /* ── Base ── */
  *,*::before,*::after{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:'Inter',sans-serif;background:#f8fafc;overflow-x:hidden}

  /* ── Hero gradient overlay ── */
  .hero-overlay{background:linear-gradient(135deg,rgba(10,31,60,.78) 0%,rgba(26,95,180,.55) 100%)}

  /* ── Gradient button ── */
  .gradient-button{background-image:linear-gradient(to right,#1d4ed8,#2563eb,#3b82f6);transition:all .3s ease}
  .gradient-button:hover{background-image:linear-gradient(to right,#1e40af,#1d4ed8,#2563eb);box-shadow:0 4px 15px rgba(37,99,235,.4)}

  /* ── Section heading underline ── */
  .section-heading{position:relative;display:inline-block;padding-bottom:10px}
  .section-heading::after{content:'';position:absolute;left:0;bottom:0;width:60%;height:4px;background:#2563eb;border-radius:2px}

  /* ── Service card hover ── */
  .service-card{transition:all .3s ease}
  .service-card:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(37,99,235,.15)}

  /* ── Testimonial card ── */
  .testi-card{transition:all .3s ease}
  .testi-card:hover{transform:translateY(-4px);box-shadow:0 12px 30px rgba(0,0,0,.1)}

  /* ── Sticky nav shadow on scroll ── */
  .nav-scrolled{box-shadow:0 2px 20px rgba(0,0,0,.1)!important}

  /* ── Form input focus ── */
  .form-input{transition:border-color .2s,box-shadow .2s}
  .form-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.15);outline:none}

  /* ── PAYMENT SECTION ── */
  .pay-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:14px;padding:28px 24px;transition:all .3s ease;cursor:pointer}
  .pay-card:hover{background:rgba(255,255,255,.13);transform:translateY(-4px)}

  /* ── MODAL ── */
  .modal-overlay{position:fixed;inset:0;z-index:9999;background:rgba(10,31,60,.85);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .3s ease}
  .modal-overlay.open{opacity:1;pointer-events:all}
  .modal-box{background:#fff;border-radius:20px;width:100%;max-width:500px;max-height:92vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.4);transform:scale(.94) translateY(16px);transition:transform .3s ease;position:relative}
  .modal-overlay.open .modal-box{transform:scale(1) translateY(0)}

  /* ── STK Push form ── */
  .stk-input{width:100%;padding:11px 13px;border:1.5px solid #d1d5db;border-radius:8px;font-size:.92rem;outline:none;transition:border-color .2s,box-shadow .2s;font-family:'Inter',sans-serif}
  .stk-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.15)}

  /* ── Card preview ── */
  .card-preview{background:linear-gradient(135deg,#1a1f71,#2d7ac5);border-radius:14px;padding:22px 20px;position:relative;overflow:hidden}
  .card-preview::before{content:'';position:absolute;right:-30px;top:-30px;width:150px;height:150px;border-radius:50%;background:rgba(255,255,255,.07)}
  .card-chip{width:38px;height:28px;border-radius:5px;background:linear-gradient(135deg,#d4af37,#f5e07c);margin-bottom:18px}

  /* ── Alert boxes ── */
  .alert-ok{background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;padding:12px 14px;border-radius:8px;font-size:.87rem;font-weight:600;margin-bottom:14px;display:none}
  .alert-er{background:#fee2e2;color:#dc2626;border:1px solid #fecaca;padding:12px 14px;border-radius:8px;font-size:.87rem;font-weight:600;margin-bottom:14px;display:none}

  /* ── Bank table ── */
  .bank-table{width:100%;border-collapse:collapse;margin-bottom:18px}
  .bank-table td{padding:10px 12px;border-bottom:1px solid #e5e7eb;font-size:.87rem}
  .bank-table td:first-child{color:#6b7280;font-weight:600;font-size:.78rem;text-transform:uppercase;letter-spacing:.05em;width:40%}
  .bank-table td:last-child{color:#1e2b3a;font-weight:700}
  .bank-table tr:last-child td{border-bottom:none}
  .copy-btn{background:#f0f7ff;border:1px solid #d4e4f5;border-radius:5px;padding:3px 9px;font-size:.7rem;cursor:pointer;color:#1a5fb4;transition:all .2s;margin-left:8px}
  .copy-btn:hover{background:#dbeafe}

  /* ── Success state ── */
  .pay-success{text-align:center;padding:20px 0;display:none}
  .pay-success .ok-icon{width:72px;height:72px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:2rem;color:#16a34a}

  /* ── Floating WhatsApp ── */
  .fab-wa{position:fixed;bottom:24px;right:24px;z-index:1000;width:54px;height:54px;border-radius:50%;background:#25d366;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.45rem;box-shadow:0 4px 22px rgba(37,211,102,.5);transition:all .3s;animation:waPulse 2.8s infinite;text-decoration:none}
  .fab-wa:hover{transform:scale(1.1)}
  @keyframes waPulse{0%,100%{box-shadow:0 4px 22px rgba(37,211,102,.5)}50%{box-shadow:0 4px 36px rgba(37,211,102,.8)}}

  /* ── Scroll-to-top ── */
  #scrollTop{position:fixed;bottom:86px;right:24px;z-index:1000;width:42px;height:42px;border-radius:8px;background:#1d4ed8;color:#fff;display:flex;align-items:center;justify-content:center;font-size:.88rem;opacity:0;pointer-events:none;transition:all .3s;cursor:pointer;border:none;box-shadow:0 4px 16px rgba(29,78,216,.4)}
  #scrollTop.show{opacity:1;pointer-events:all}
  #scrollTop:hover{background:#1e40af}

  /* ── Reveal animation ── */
  .reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}
  .reveal.visible{opacity:1;transform:none}

  /* ── Mobile menu ── */
  #mobileMenu{max-height:0;overflow:hidden;transition:max-height .35s ease}
  #mobileMenu.open{max-height:400px}

  /* ── Stats strip ── */
  .stat-card{background:#fff;border-radius:10px;padding:20px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:all .3s}
  .stat-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.12)}
</style>
</head>
