<!-- ════ WHY CHOOSE US ════ -->
<section id="why" class="py-16 md:py-24 bg-blue-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 reveal">
      <h2 class="text-4xl font-bold mb-4 section-heading mx-auto w-fit">Why Choose GLACIER HVAC?</h2>
      <p class="text-gray-600 text-lg mt-6 max-w-2xl mx-auto">We're committed to excellence in every job — big or small.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-xl shadow-md flex items-start gap-4 hover:scale-105 transition-transform duration-300 reveal">
        <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0"><i class="fas fa-user-check text-white text-lg"></i></div>
        <div><h3 class="text-lg font-bold mb-1">Certified Technicians</h3><p class="text-gray-600 text-sm">Highly trained professionals with 10+ years of HVAC expertise.</p></div>
