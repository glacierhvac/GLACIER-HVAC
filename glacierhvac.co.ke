          </div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1">Amount (KES) *</label><input type="number" id="card-amount" class="stk-input" placeholder="e.g. 12000" min="1"></div>
            <div>
              <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1">Service *</label>
