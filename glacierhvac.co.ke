<!-- ════════════════════════════════════════
     JAVASCRIPT — All functionality
════════════════════════════════════════ -->
<script>
/* ══════════════════════════════════════════════════════
   PAYMENT CONFIG
   ──────────────────────────────────────────────────────
   SETUP STEPS (one-time, 5 minutes):
   1. Go to https://dashboard.flutterwave.com → sign up free
   2. Complete business verification
   3. Settings → API Keys → copy your LIVE Public Key
   4. Replace FLWPUBK_TEST-... below with your LIVE key
   5. Both M-Pesa STK push and card payments go live instantly

   TEST credentials (safe to use, no real money):
   • M-Pesa phone: 0708374149
   • Card: 4187427415564246 | 09/32 | CVV 828 | PIN 3310 | OTP 12345
══════════════════════════════════════════════════════ */
const FLW_KEY         = 'FLWPUBK_TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-X'; // ← REPLACE WITH YOUR LIVE KEY
const BIZ_NAME        = 'Glacier HVAC Solutions';
const BIZ_EMAIL       = 'glacierhvacsolution@gmail.com';
const NOTIFY_URL      = 'https://formspree.io/f/xwvzqyga'; // emails glacierhvacsolution@gmail.com

function txRef() { return 'GHVAC-' + Date.now() + '-' + Math.random().toString(36).substr(2,5).toUpperCase(); }

function notifyEmail(subject, data) {
  fetch(NOTIFY_URL, {
    method:'POST',
    headers:{'Content-Type':'application/json','Accept':'application/json'},
    body: JSON.stringify({...data, _subject: subject})
  }).catch(()=>{});
}

/* ── MODAL ── */
function openModal(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
  const fw = document.getElementById(id).querySelector('[id$="-form-wrap"]');
  const ss = document.getElementById(id).querySelector('.pay-success');
  if(fw) fw.style.display='';
  if(ss) ss.style.display='none';
}
document.querySelectorAll('.modal-overlay').forEach(ov => {
  ov.addEventListener('click', function(e){ if(e.target===this) closeModal(this.id); });
});
document.addEventListener('keydown', e => {
  if(e.key==='Escape') document.querySelectorAll('.modal-overlay.open').forEach(m=>closeModal(m.id));
});

/* ── STK ALERT ── */
function showStkAlert(msg, type) {
  const el = document.getElementById('stk-alert');
  el.className = type==='error' ? 'alert-er' : 'alert-ok';
  el.innerHTML = '<i class="fas fa-'+(type==='error'?'exclamation-circle':'check-circle')+'"></i> '+msg;
  el.style.display = 'block';
}

/* ── M-PESA STK PUSH via Daraja (Till 9281612) ── */
/* SETUP: Deploy the Apps Script backend and set DARAJA_STK_URL below */
const DARAJA_STK_URL = 'YOUR_APPS_SCRIPT_STK_URL'; // ← Paste your Apps Script URL after deploying

function sendDarajaSTK() {
  const rawPhone = document.getElementById('stk-phone').value.trim().replace(/\s/g,'');
  const amount   = parseFloat(document.getElementById('stk-amount').value.trim());
  const service  = document.getElementById('stk-service').value;
  const name     = document.getElementById('stk-name').value.trim() || 'Glacier HVAC Customer';

  if(!rawPhone || !amount || !service){
    showStkAlert('Please fill in phone number, amount and service.','error'); return;
  }
  if(!/^(07|01)\d{8}$/.test(rawPhone)){
    showStkAlert('Enter a valid Safaricom number: 07XXXXXXXX','error'); return;
  }
  if(isNaN(amount)||amount<1){
    showStkAlert('Please enter a valid amount (minimum KES 1).','error'); return;
  }

  const btn = document.getElementById('stk-btn');
  btn.disabled=true;
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Sending push…';

  /* Send to Daraja backend via Apps Script */
  fetch(DARAJA_STK_URL, {
    method: 'POST',
    mode: 'no-cors',
    body: new URLSearchParams({ phone: rawPhone, amount, service, name })
  }).then(() => {
    /* Show success — STK push sent */
    document.getElementById('mpesa-form-wrap').style.display='none';
    document.getElementById('mpesa-success').style.display='block';
  }).catch(() => {
    showStkAlert('Network error. Please pay manually using Till 9281612.','error');
    btn.disabled=false;
    btn.innerHTML='<i class="fas fa-paper-plane"></i> Send STK Push to My Phone';
  });
}

/* Legacy Flutterwave sendSTK — kept for reference */
function sendSTK() {
  const rawPhone = document.getElementById('stk-phone').value.trim().replace(/\s/g,'');
  const amount   = parseFloat(document.getElementById('stk-amount').value.trim());
  const service  = document.getElementById('stk-service').value;
  const name     = document.getElementById('stk-name').value.trim() || 'Glacier HVAC Customer';
  const email    = document.getElementById('stk-email').value.trim() || BIZ_EMAIL;

  if(!rawPhone || !amount || !service){
    showStkAlert('Please fill in phone number, amount and service.','error'); return;
  }
  if(!/^(07|01)\d{8}$/.test(rawPhone)){
    showStkAlert('Enter a valid Safaricom number: 07XXXXXXXX','error'); return;
  }
  if(isNaN(amount)||amount<1){
    showStkAlert('Please enter a valid amount (minimum KES 1).','error'); return;
  }
  const phone254 = '254'+rawPhone.substring(1);
  const btn = document.getElementById('stk-btn');
  btn.disabled=true;
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Sending push…';

  FlutterwaveCheckout({
    public_key:      FLW_KEY,
    tx_ref:          txRef(),
    amount:          amount,
    currency:        'KES',
    payment_options: 'mpesa',
    customer:{ email, phone_number:phone254, name },
    meta:{ service },
    customizations:{ title:BIZ_NAME, description:'Payment for: '+service },
    callback: function(res){
      btn.disabled=false;
      btn.innerHTML='<i class="fas fa-paper-plane"></i> Send STK Push to My Phone';
      if(res.status==='successful'||res.status==='completed'){
        document.getElementById('mpesa-form-wrap').style.display='none';
        document.getElementById('mpesa-success').style.display='block';
        notifyEmail('✅ M-Pesa Payment — Glacier HVAC',{customer:name,phone:rawPhone,service,amount:'KES '+amount,tx_id:res.transaction_id,status:res.status});
      } else {
        showStkAlert('Payment not completed. Try again or use Paybill above.','error');
      }
    },
    onclose: function(){
      btn.disabled=false;
      btn.innerHTML='<i class="fas fa-paper-plane"></i> Send STK Push to My Phone';
    }
  });
}

/* ── CARD PREVIEW ── */
function updatePreview(){
  const n = document.getElementById('card-name');
  document.getElementById('prev-name').textContent = (n&&n.value) ? n.value.toUpperCase() : 'YOUR NAME';
}

/* ── CARD ALERT ── */
function showCardAlert(msg, type) {
  const el = document.getElementById('card-alert');
  el.className = type==='error' ? 'alert-er' : 'alert-ok';
  el.innerHTML = '<i class="fas fa-'+(type==='error'?'exclamation-circle':'check-circle')+'"></i> '+msg;
  el.style.display='block';
}

/* ── VISA / CARD PAYMENT via Flutterwave ── */
function processCard(){
  const name   = document.getElementById('card-name').value.trim();
  const email  = document.getElementById('card-email').value.trim();
  const phone  = document.getElementById('card-phone').value.trim();
  const amount = parseFloat(document.getElementById('card-amount').value.trim());
  const svc    = document.getElementById('card-service').value;

  if(!name||!email||!amount||!svc){
    showCardAlert('Please fill in all required fields.','error'); return;
  }
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    showCardAlert('Please enter a valid email address.','error'); return;
  }
  if(isNaN(amount)||amount<1){
    showCardAlert('Please enter a valid amount (minimum KES 1).','error'); return;
  }
  const btn = document.getElementById('visa-pay-btn');
  btn.disabled=true;
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Opening secure payment…';

  FlutterwaveCheckout({
    public_key:      FLW_KEY,
    tx_ref:          txRef(),
    amount:          amount,
    currency:        'KES',
    payment_options: 'card',
    customer:{ email, phone_number:phone||'', name },
    meta:{ service:svc },
    customizations:{ title:BIZ_NAME, description:'Payment for: '+svc },
    callback: function(res){
      btn.disabled=false;
      btn.innerHTML='<i class="fas fa-lock"></i> Continue to Secure Payment';
      if(res.status==='successful'||res.status==='completed'){
        document.getElementById('visa-form-wrap').style.display='none';
        document.getElementById('visa-success').style.display='block';
        notifyEmail('✅ Card Payment — Glacier HVAC',{customer:name,email,service:svc,amount:'KES '+amount,tx_id:res.transaction_id,status:res.status,note:'Card details NOT included — PCI compliance'});
      } else {
        showCardAlert('Payment was not completed. Please try again or use a different card.','error');
      }
    },
    onclose: function(){
      btn.disabled=false;
      btn.innerHTML='<i class="fas fa-lock"></i> Continue to Secure Payment';
    }
  });
}

/* ── COPY BANK DETAILS ── */
function copyText(txt, btn) {
  navigator.clipboard.writeText(txt).then(()=>{
    btn.innerHTML='<i class="fas fa-check"></i>';
    btn.style.color='#16a34a';
    setTimeout(()=>{ btn.innerHTML='<i class="fas fa-copy"></i>'; btn.style.color=''; }, 1800);
  }).catch(()=>{
    const t=document.createElement('textarea');
    t.value=txt; document.body.appendChild(t); t.select();
    document.execCommand('copy'); document.body.removeChild(t);
    btn.innerHTML='<i class="fas fa-check"></i>';
    setTimeout(()=>btn.innerHTML='<i class="fas fa-copy"></i>',1800);
  });
}

/* ═══════════════════════════════════════════
   CONTACT FORM — Web3Forms (free, client-side, no server needed)
   Submissions emailed to glacierhvacsolution@gmail.com instantly
═══════════════════════════════════════════ */
const W3F_KEY = '55418ee3-1f9b-4732-a054-afb26952d441';
const cForm   = document.getElementById('contactForm');
const cAlert  = document.getElementById('formAlert');
const cBtn    = document.getElementById('submitBtn');

function showFormAlert(type, html){
  cAlert.className = 'mb-4 p-3 rounded-lg text-sm font-semibold '+(type==='ok'?'bg-green-100 text-green-700 border border-green-300':'bg-red-100 text-red-700 border border-red-300');
  cAlert.innerHTML = html;
  cAlert.classList.remove('hidden');
  cAlert.scrollIntoView({behavior:'smooth',block:'nearest'});
}

cForm.addEventListener('submit', async function(e){
  e.preventDefault();
  const name     = cForm.querySelector('[name=name]').value.trim();
  const phone    = cForm.querySelector('[name=phone]').value.trim();
  const email    = cForm.querySelector('[name=email]').value.trim();
  const service  = cForm.querySelector('[name=service]').value;
  const location = cForm.querySelector('[name=location]') ? cForm.querySelector('[name=location]').value.trim() : '';
  const message  = cForm.querySelector('[name=message]').value.trim();

  if(!name||!phone||!email||!service||!message){
    showFormAlert('er','<i class="fas fa-exclamation-circle mr-1"></i> Please fill in all required fields.'); return;
  }
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    showFormAlert('er','<i class="fas fa-exclamation-circle mr-1"></i> Please enter a valid email address.'); return;
  }
  cBtn.disabled=true;
  cBtn.innerHTML='<i class="fas fa-spinner fa-spin mr-2"></i> Sending…';
  cAlert.classList.add('hidden');

  try{
    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: {'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify({
        access_key: W3F_KEY,
        subject: '🔔 New HVAC Enquiry: '+service+' from '+name,
        from_name: 'Glacier HVAC Website',
        name, phone, email, service, location, message,
        botcheck: ''
      })
    });
    const data = await res.json();
    if(data.success){
      showFormAlert('ok','<i class="fas fa-check-circle mr-1"></i> <strong>Message sent!</strong> Thank you, '+name+'! We\'ll contact you within 1 hour.');
      cForm.reset();
    } else {
      showFormAlert('er','<i class="fas fa-exclamation-circle mr-1"></i> '+(data.message||'Submission failed. Please try again.'));
    }
  } catch(err){
    showFormAlert('er','<i class="fas fa-exclamation-circle mr-1"></i> Network error. Call us: <a href="tel:+254748471841" class="underline font-bold">+254 748 471 841</a>');
  } finally {
    cBtn.disabled=false;
    cBtn.innerHTML='<i class="fas fa-paper-plane mr-2"></i> Send Message';
  }
});

/* ═══════════════════════════════════════════
   MOBILE MENU
═══════════════════════════════════════════ */
const hamburger  = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
const hamIcon    = document.getElementById('ham-icon');

hamburger.addEventListener('click',()=>{
  mobileMenu.classList.toggle('open');
  hamIcon.className = mobileMenu.classList.contains('open') ? 'fas fa-times text-xl' : 'fas fa-bars text-xl';
});
mobileMenu.querySelectorAll('a').forEach(a=>{
  a.addEventListener('click',()=>{
    mobileMenu.classList.remove('open');
    hamIcon.className='fas fa-bars text-xl';
  });
});

/* ═══════════════════════════════════════════
   SMOOTH SCROLL (fixed: no crash on #-only hrefs)
═══════════════════════════════════════════ */
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',function(e){
    const href = this.getAttribute('href');
    if(!href||href==='#') return;
    const target = document.querySelector(href);
    if(!target) return;
    e.preventDefault();
    window.scrollTo({top:target.getBoundingClientRect().top+window.scrollY-68,behavior:'smooth'});
  });
});

/* ═══════════════════════════════════════════
   SCROLL EFFECTS
═══════════════════════════════════════════ */
const navbar = document.getElementById('navbar');
const scrollTopBtn = document.getElementById('scrollTop');

window.addEventListener('scroll',()=>{
  // Navbar shadow
  navbar.classList.toggle('nav-scrolled', window.scrollY>10);
  // Scroll-to-top visibility
  scrollTopBtn.classList.toggle('show', window.scrollY>500);
});

/* ═══════════════════════════════════════════
   ACTIVE NAV LINK on scroll
═══════════════════════════════════════════ */
const allSections = document.querySelectorAll('section[id]');
const navLinks    = document.querySelectorAll('.nav-link');
allSections.forEach(sec=>{
  new IntersectionObserver(entries=>{
    entries.forEach(en=>{
      if(en.isIntersecting)
        navLinks.forEach(a=>a.classList.toggle('text-blue-600',a.getAttribute('href')==='#'+en.target.id));
    });
  },{rootMargin:'-40% 0px -55% 0px'}).observe(sec);
});

/* ═══════════════════════════════════════════
   SCROLL REVEAL
═══════════════════════════════════════════ */
new IntersectionObserver((entries,obs)=>{
  entries.forEach(en=>{
    if(en.isIntersecting){en.target.classList.add('visible');obs.unobserve(en.target);}
  });
},{threshold:0.1}).observe && (() => {
  const ro = new IntersectionObserver((entries,obs)=>{
    entries.forEach(en=>{if(en.isIntersecting){en.target.classList.add('visible');obs.unobserve(en.target);}});
  },{threshold:0.1});
  document.querySelectorAll('.reveal').forEach((el,i)=>{
    el.style.transitionDelay=(i%4)*0.09+'s';
    ro.observe(el);
  });
})();
</script>
</body>
</html>
